# ClankerStudios environment template.
# Copy to `.env` and fill in whatever you actually need.
# `.env` is gitignored; `.env.example` is not.
#
# Nothing here is read automatically — the scripts call os.getenv at
# use time. If a key is missing, the feature that needs it fails soft
# (TTS) or raises when the backend is invoked (OpenAI).

# --- OpenAI (only for configs that set llm_backend: openai) -------------------
# Used by src/llm/openai_backend.py. Leave blank if you only run Gemma via vLLM.
OPENAI_API_KEY=

# --- ElevenLabs TTS (only when audio_enabled: true) ---------------------------
# Used by src/tts/elevenlabs.py. The voice_id itself lives in the run config
# (configs/*.yaml → elevenlabs_voice_id), not here.
ELEVENLABS_API_KEY=

# --- vLLM / local Gemma (optional overrides) ----------------------------------
# Used by src/llm/gemma.py. Defaults match a vLLM server started with
# `vllm serve ... --port 8000`; override only if your server lives elsewhere.
# VLLM_API_KEY is not verified by vLLM, but the OpenAI SDK requires a non-empty
# value — the code defaults to "EMPTY" if you leave this unset.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
